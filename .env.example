# ─────────────────────────────────────────────────────────────────────────────
# FlyttGo — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (required)
VITE_SUPABASE_URL=https://jomhtghowrtegjfddite.databasepad.com
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps (required for address autocomplete in HomePage)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe (optional — only needed if Stripe checkout is live)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
