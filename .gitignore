# Dependencies
node_modules
.pnp
.pnp.js

# Build output
dist
dist-ssr
build

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor / OS
.DS_Store
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vercel — ignore everything inside .vercel/ except project.json,
# which pins the repo to the canonical Vercel project.
# (.vercel/.env.* — pulled by `vercel env pull` — stays ignored.)
# Note: must use `.vercel/*` (not `.vercel`) so the `!` exception
# below can re-include a single file. Git refuses to re-include a
# child of a fully-ignored directory.
.vercel/*
!.vercel/project.json
